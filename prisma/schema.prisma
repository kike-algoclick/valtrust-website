generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model BuyerProfile {
  clerkId   String     @id
  firstName String
  lastName  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  favorites Favorite[]
}

model SellerProfile {
  clerkId            String                @id
  firstName          String
  lastName           String
  email              String
  phone              String
  isIdentityVerified Boolean               @default(false)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  verification       IdentityVerification?
  properties         Property[]
  valuations         Valuation[]
}

model IdentityVerification {
  sellerClerkId  String             @id
  duiNumber      String?
  duiImageUrl    String
  selfieImageUrl String
  extractedName  String?
  status         VerificationStatus @default(pending)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  seller         SellerProfile      @relation(fields: [sellerClerkId], references: [clerkId], onDelete: Cascade)
}

model Valuation {
  id                      Int            @id @default(autoincrement())
  publicId                String         @unique @default(uuid())
  sellerClerkId           String?
  department              String
  municipality            String
  zone                    String
  exactAddress            String?
  postalCode              Int?
  type                    String
  condition               String
  areaM2                  Float
  landAreaM2              Float?
  levels                  Int
  yearBuilt               Int
  bedrooms                Int
  bathrooms               Int
  parkingSpaces           Int?
  kitchenType             String
  hasLivingDiningRoom     Boolean?
  hasLaundryRoom          Boolean?
  hasStorageCellar        Boolean?
  hasStudioHomeOffice     Boolean?
  hasServiceQuarter       Boolean?
  hasAC                   Boolean?
  hasSmartHome            Boolean?
  hasPool                 Boolean?
  hasSecurityGate         Boolean?
  hasCCTV                 Boolean?
  hasGym                  Boolean?
  hasElevator             Boolean?
  hasGreenAreas           Boolean?
  hasOtherAmenity         Boolean?
  otherAmenityDescription String?
  publicDescription       String?
  maintenanceFee          Float?
  petsAllowed             String?
  includedServices        String?
  estimatedMin            Float
  estimatedMax            Float
  estimatedValue          Float
  pricePerM2              Float
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  property                Property?
  seller                  SellerProfile? @relation(fields: [sellerClerkId], references: [clerkId])

  @@index([sellerClerkId])
}

model Property {
  id                 String                     @id @default(uuid())
  sellerClerkId      String
  valuationId        Int?                       @unique
  title              String
  description        String
  location           String
  address            String
  latitude           Float?
  longitude          Float?
  status             PropertyStatus             @default(available)
  verificationStatus PropertyVerificationStatus @default(unverified)
  areaM2             Float
  rooms              Int
  bathrooms          Int
  price              Float
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  favorites          Favorite[]
  seller             SellerProfile              @relation(fields: [sellerClerkId], references: [clerkId], onDelete: Cascade)
  valuation          Valuation?                 @relation(fields: [valuationId], references: [id])
  deed               PropertyDeed?
  photos             PropertyPhoto[]
  views              PropertyView[]

  @@index([sellerClerkId])
  @@index([location])
  @@index([price])
}

model PropertyPhoto {
  id         String   @id @default(uuid())
  propertyId String
  url        String
  order      Int
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model PropertyDeed {
  id              String             @id @default(uuid())
  propertyId      String             @unique
  documentUrl     String
  ownerName       String?
  propertyAddress String?
  extractedText   String?
  status          VerificationStatus @default(pending)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  property        Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Favorite {
  id                  String        @id @default(uuid())
  clerkId             String
  propertyId          String
  savedAt             DateTime      @default(now())
  buyerProfileClerkId String?
  buyerProfile        BuyerProfile? @relation(fields: [buyerProfileClerkId], references: [clerkId])
  property            Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([clerkId, propertyId])
  @@index([clerkId])
  @@index([propertyId])
}

model PropertyView {
  id            String   @id @default(uuid())
  propertyId    String
  viewerClerkId String?
  viewedAt      DateTime @default(now())
  property      Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model SiteComment {
  id        String   @id @default(uuid())
  clerkId   String
  role      Role
  comment   String
  createdAt DateTime @default(now())

  @@index([clerkId])
}

model AIConversation {
  id        String      @id @default(uuid())
  clerkId   String
  title     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  messages  AIMessage[]
}

model AIMessage {
  id             String         @id @default(uuid())
  conversationId String
  role           String
  content        String
  createdAt      DateTime       @default(now())
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

enum Role {
  buyer
  seller
  admin
}

enum PropertyStatus {
  available
  sold
}

enum PropertyVerificationStatus {
  unverified
  valuation_verified
  deed_verified
  fully_verified
}

enum VerificationStatus {
  pending
  verified
  failed
}
